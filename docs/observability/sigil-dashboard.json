{
  "uid": "sigil-scenarios",
  "title": "Sigil scenario runs",
  "tags": ["sigil", "scenarios"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## Sigil scenario runs\nRED metrics + a trace table over `sigil test --otlp` runs (service `sigil-test`). Stats span the dashboard time range; the tables list individual runs — click a row to open the step span tree (durations, `extract` bind events, the failing step's message)."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Scenarios (in range)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
          "expr": "sum(increase(traces_spanmetrics_calls_total{service=\"sigil-test\", span_name=~\"scenario:.*\"}[$__range])) or vector(0)",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errored scenarios (in range)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
          "expr": "sum(increase(traces_spanmetrics_calls_total{service=\"sigil-test\", span_name=~\"scenario:.*\", status_code=\"STATUS_CODE_ERROR\"}[$__range])) or vector(0)",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Step latency p50",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=\"sigil-test\"}[$__rate_interval])))",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Step latency p95",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=\"sigil-test\"}[$__rate_interval])))",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none", "textMode": "value" }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Step latency percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
      "targets": [
        {
          "refId": "p50",
          "legendFormat": "p50",
          "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=\"sigil-test\"}[$__rate_interval])))"
        },
        {
          "refId": "p95",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=\"sigil-test\"}[$__rate_interval])))"
        },
        {
          "refId": "p99",
          "legendFormat": "p99",
          "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=\"sigil-test\"}[$__rate_interval])))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "auto" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Scenario throughput by status",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "{{status_code}}",
          "datasource": { "type": "prometheus", "uid": "__PROM_UID__" },
          "expr": "sum by (status_code) (rate(traces_spanmetrics_calls_total{service=\"sigil-test\", span_name=~\"scenario:.*\"}[$__rate_interval]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "STATUS_CODE_OK" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] },
          { "matcher": { "id": "byName", "options": "STATUS_CODE_ERROR" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Recent runs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "tempo", "uid": "__TEMPO_UID__" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "__TEMPO_UID__" },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"sigil-test\" }",
          "tableType": "traces",
          "limit": 100
        }
      ],
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Failed runs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 25 },
      "datasource": { "type": "tempo", "uid": "__TEMPO_UID__" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "__TEMPO_UID__" },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"sigil-test\" && status = error }",
          "tableType": "traces",
          "limit": 100
        }
      ],
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [] }
    }
  ]
}
