(() => {
  let c1 = false;
  let c2 = 0;
  const n_1_1_text = document.querySelector('[data-sid="/1/1"]');
  let n_2_0_1_text = null;
  let if_2_mounted = false;
  const mount_2 = (root) => {
    n_2_0_1_text = root.querySelector('[data-sid="/2/0/1"]');
    n_2_0_1_text.textContent = "count is bound here too: " + String(c2);
  };
  const unmount_2 = () => {
    n_2_0_1_text = null;
  };
  const update_c1 = () => {
    const want_2 = !!c1;
    if (want_2 !== if_2_mounted) {
      const cur = document.querySelector('[data-sid="/2"]');
      if (want_2) {
        const live = document.createElement('div');
        for (const a of cur.attributes) live.setAttribute(a.name, a.value);
        for (const node of cur.content.childNodes) live.appendChild(node.cloneNode(true));
        cur.replaceWith(live);
        mount_2(live);
      } else {
        const tmpl = document.createElement('template');
        for (const a of cur.attributes) tmpl.setAttribute(a.name, a.value);
        while (cur.firstChild) tmpl.content.appendChild(cur.firstChild);
        cur.replaceWith(tmpl);
        unmount_2();
      }
      if_2_mounted = want_2;
    }
  };
  const update_c2 = () => {
    n_1_1_text.textContent = "count: " + String(c2);
    if (n_2_0_1_text) n_2_0_1_text.textContent = "count is bound here too: " + String(c2);
  };
  document.querySelector('[data-sid="/1/0"]').onclick = (event) => {
    c1 = !c1;
    update_c1();
  };
  document.querySelector('[data-sid="/1/2"]').onclick = (event) => {
    c2 = c2 + 1;
    update_c2();
  };
  window.__sigil_cells = new Proxy({}, { get(_, p) {
    if (p === "c1") return c1;
    if (p === "c2") return c2;
    return undefined;
  }});
})();
