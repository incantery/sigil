  mount__1(document.querySelector('[data-sid="/1"] [data-sigil-for-item="c1"]'), "c1");
  mount__1(document.querySelector('[data-sid="/1"] [data-sigil-for-item="c2"]'), "c2");
  mount__1(document.querySelector('[data-sid="/1"] [data-sigil-for-item="c3"]'), "c3");
  window.__sigil_cells = new Proxy({}, { get(_, p) {
