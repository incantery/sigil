(() => {
  let c4 = ["c1", "c2", "c3"];
  const cells_c4 = { c1: 0, c2: 0, c3: 0 };
  const rows_c4 = Object.create(null);
  let counter_c4 = 0;
  const mount__1 = (rowEl, cellId) => {
    rows_c4[cellId] = rowEl;
    let e_0_0 = rowEl.children[0].children[0];
    let e_0_1 = rowEl.children[0].children[1];
    let e_0_2 = rowEl.children[0].children[2];
    let e_0_3 = rowEl.children[0].children[3];
    e_0_1.textContent = String(cells_c4[cellId]);
    e_0_0.onclick = (event) => { cells_c4[cellId] = cells_c4[cellId] + -1; e_0_1.textContent = String(cells_c4[cellId]); };
    e_0_2.onclick = (event) => { cells_c4[cellId] = cells_c4[cellId] + 1; e_0_1.textContent = String(cells_c4[cellId]); };
    e_0_3.onclick = (event) => { remove_c4(cellId); };
  };
  const tmpl__1 = document.querySelector('[data-sid="/1"] template[data-sigil-for-template]');
  const append_c4 = (value) => {
    const newId = 'r' + (++counter_c4);
    cells_c4[newId] = value;
