(() => {
  const ADJ = ["pretty","large","big","small","tall","short","long","handsome","plain","quaint","clean","elegant","easy","angry","crazy","helpful","mushy","odd","unsightly","adorable","important","inexpensive","cheap","expensive","fancy"];
  const COL = ["red","yellow","blue","green","pink","brown","purple","brown","white","black","orange"];
  const NOUN = ["table","chair","house","bbq","desk","car","pony","cookie","sandwich","burger","pizza","mouse","keyboard"];
  const pick = (a) => a[(Math.random() * a.length) | 0];
  const randomLabel = () => pick(ADJ) + " " + pick(COL) + " " + pick(NOUN);
  let c1 = [];
  const cells_c1 = {};
  const rows_c1 = Object.create(null);
  let counter_c1 = 0;
  const mount__2 = (rowEl, cellId) => {
    rows_c1[cellId] = rowEl;
    let e_0_0 = rowEl.children[0].children[0];
    let e_0_1 = rowEl.children[0].children[1];
    let e_0_2 = rowEl.children[0].children[2];
    e_0_0.textContent = String(cells_c1[cellId]);
    e_0_1.onclick = (event) => { /* unsupported row action "select_in_list" */ };
    e_0_2.onclick = (event) => { remove_c1(cellId); };
  };
  const tmpl__2 = document.querySelector('[data-sid="/2"] template[data-sigil-for-template]');
  const wrapper__2 = document.querySelector('[data-sid="/2"]');
  let selected_c1 = '';
  const clear_c1 = () => {
    c1.length = 0;
    for (const k of Object.keys(cells_c1)) delete cells_c1[k];
    for (const k of Object.keys(rows_c1)) delete rows_c1[k];
    wrapper__2.textContent = '';
    wrapper__2.appendChild(tmpl__2);
    selected_c1 = '';
  };
  const swap_items_c1 = (i, j) => {
    if (i < 0 || j < 0 || i >= c1.length || j >= c1.length || i === j) return;
    const ai = c1[i], aj = c1[j];
    c1[i] = aj; c1[j] = ai;
    const rowI = wrapper__2.querySelector('[data-sigil-for-item="' + ai + '"]');
    const rowJ = wrapper__2.querySelector('[data-sigil-for-item="' + aj + '"]');
    if (!rowI || !rowJ) return;
    const marker = document.createComment('');
    rowJ.parentNode.insertBefore(marker, rowJ);
    rowI.parentNode.insertBefore(rowJ, rowI);
    marker.parentNode.insertBefore(rowI, marker);
    marker.remove();
  };
  const create_batch_random_c1 = (count, replace) => {
    if (replace) clear_c1();
    const frag = document.createDocumentFragment();
    for (let i = 0; i < count; i++) {
      const newId = 'r' + (++counter_c1);
      const label = randomLabel();
      cells_c1[newId] = label;
      c1.push(newId);
      const row = tmpl__2.content.cloneNode(true).firstElementChild;
      row.setAttribute('data-sigil-for-item', newId);
      frag.appendChild(row);
      mount__2(row, newId);
    }
    tmpl__2.parentNode.insertBefore(frag, tmpl__2);
  };
  const update_every_c1 = (stride, suffix) => {
    if (stride <= 0) return;
    for (let i = 0; i < c1.length; i += stride) {
      const id = c1[i];
      cells_c1[id] = String(cells_c1[id]) + suffix;
      const r = rows_c1[id];
      if (r) mount__2(r, id);
    }
  };
  document.querySelector('[data-sid="/1/0"]').onclick = (event) => {
    create_batch_random_c1(1000, true);
  };
  document.querySelector('[data-sid="/1/1"]').onclick = (event) => {
    create_batch_random_c1(10000, true);
  };
  document.querySelector('[data-sid="/1/2"]').onclick = (event) => {
    create_batch_random_c1(1000, false);
  };
  document.querySelector('[data-sid="/1/3"]').onclick = (event) => {
    update_every_c1(10, " !!!");
  };
  document.querySelector('[data-sid="/1/4"]').onclick = (event) => {
    clear_c1();
  };
  document.querySelector('[data-sid="/1/5"]').onclick = (event) => {
    swap_items_c1(1, 998);
  };
  window.__sigil_cells = new Proxy({}, { get(_, p) {
    if (p === "c1") return c1;
    if (p in cells_c1) return cells_c1[p];
    return undefined;
  }});
})();
