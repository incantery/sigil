{
  "comments": { "lineComment": "//" },
  "brackets": [["{", "}"], ["[", "]"], ["(", ")"]],
  "autoClosingPairs": [
    { "open": "{", "close": "}" }, { "open": "[", "close": "]" },
    { "open": "(", "close": ")" }, { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [["{","}"],["[","]"],["(",")"],["\"","\""]],
  "indentationRules": {
    "increaseIndentPattern": "(=|->|with|then|else)\\s*$",
    "decreaseIndentPattern": "^\\s*(else|\\|)"
  }
}
