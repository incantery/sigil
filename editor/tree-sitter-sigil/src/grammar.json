            "name": "parameter"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "SYMBOL",
          "name": "_expression"
        }
      ]
    },
    "pub": {
      "type": "STRING",
      "value": "pub"
    },
    "rec": {
      "type": "STRING",
      "value": "rec"
    },
    "parameter": {
      "type": "SYMBOL",
      "name": "identifier"
    },
    "import_decl": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "import"
        },
        {
