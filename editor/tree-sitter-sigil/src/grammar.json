                "type": "SYMBOL",
                "name": "application"
              },
              {
                "type": "SYMBOL",
                "name": "_atom"
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "_atom"
          }
        ]
      }
    },
    "_atom": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "uident"
        },
        {
          "type": "SYMBOL",
          "name": "hole"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "float"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "unit"
        },
        {
          "type": "SYMBOL",
          "name": "list"
        },
        {
          "type": "SYMBOL",
