{
  "grammars": [
    {
      "name": "sigil",
      "camelcase": "Sigil",
      "scope": "source.mako",
      "path": ".",
      "file-types": ["sigil"],
      "highlights": ["queries/highlights.scm"],
      "locals": ["queries/locals.scm"],
      "injections": ["queries/injections.scm"]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Sigil language",
    "authors": [{"name": "Sigil"}],
    "links": {
      "repository": "https://github.com/incantery/mako"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
